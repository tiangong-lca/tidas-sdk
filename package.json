{
  "name": "tidas-sdk",
  "private": true,
  "workspaces": [
    "sdks/typescript",
    "sdks/typescript/examples"
  ],
  "scripts": {
    "bootstrap": "npm install --workspaces",
    "build:typescript": "npm --workspace @tiangong-lca/tidas-sdk run build",
    "test:typescript": "npm --workspace @tiangong-lca/tidas-sdk run test",
    "verify:typescript": "./scripts/ci/verify-typescript-package.sh",
    "verify:python": "./scripts/ci/verify-python-package.sh",
    "release:prepare:patch:typescript": "npm --workspace @tiangong-lca/tidas-sdk run release:prepare:patch",
    "release:prepare:minor:typescript": "npm --workspace @tiangong-lca/tidas-sdk run release:prepare:minor",
    "release:prepare:major:typescript": "npm --workspace @tiangong-lca/tidas-sdk run release:prepare:major"
  }
}
