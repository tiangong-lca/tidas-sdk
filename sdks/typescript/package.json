{
  "name": "@tiangong-lca/tidas-sdk",
  "version": "0.1.31",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js",
      "require": "./dist/schemas/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.js"
    },
    "./parity": {
      "types": "./dist/parity/index.d.ts",
      "import": "./dist/parity/index.js",
      "require": "./dist/parity/index.js"
    },
    "./xml": {
      "types": "./dist/xml/index.d.ts",
      "import": "./dist/xml/index.js",
      "require": "./dist/xml/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js",
      "require": "./dist/tools/index.js"
    }
  },
  "scripts": {
    "build": "tsx scripts/bundle-methodologies.ts && tsc && tsx scripts/copy-runtime-assets.ts",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run lint && npm run typecheck && npm test && npm run build",
    "bundle-methodologies": "tsx scripts/bundle-methodologies.ts",
    "sync-runtime-assets": "tsx scripts/sync-runtime-assets.ts",
    "copy-runtime-assets": "tsx scripts/copy-runtime-assets.ts",
    "generate-types": "tsx scripts/generate-types.ts",
    "generate-schemas": "tsx scripts/generate-zod-schemas.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "verify:release": "bash ../../scripts/ci/verify-typescript-package.sh",
    "release:prepare:patch": "npm version patch --no-git-tag-version",
    "release:prepare:minor": "npm version minor --no-git-tag-version",
    "release:prepare:major": "npm version major --no-git-tag-version"
  },
  "keywords": [
    "tidas",
    "ilcd",
    "lca",
    "typescript",
    "sdk"
  ],
  "author": "",
  "license": "MIT",
  "description": "TypeScript SDK for ILCD/Tidas data management",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tiangong-lca/tidas-sdk.git",
    "directory": "sdks/typescript"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.14",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "dotenv": "^17.2.1",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "jest": "^30.0.4",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.36.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@langchain/core": "^0.3.72",
    "jsonschema": "^1.5.0",
    "langchain": "^0.3.31",
    "ts-to-zod": "^3.15.0",
    "xmltodict": "^1.0.5",
    "yaml": "^2.8.1",
    "zod": "^4.0.5"
  }
}
